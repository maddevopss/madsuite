# Template de developpement Docker.
# Copier ce fichier vers .env.docker.local, puis remplacer les valeurs CHANGE_ME.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=1234

# JWT (minimum 32 caracteres)
JWT_SECRET=CHANGE_ME_GENERATE_A_32_BYTE_SECRET
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=10

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=1234
