# MADSuite - client delivery template
# Copy the relevant block into the component .env file that uses it.
#
# Backend:
#   copy to backend/.env
# Frontend:
#   copy to frontend/.env if you want local Vite overrides
# Desktop agent:
#   copy to desktop-agent/.env when you want local agent overrides
#
# Keep secrets out of Git.

# ----------------------------
# Backend / server
# ----------------------------
NODE_ENV=production
PORT=5000

JWT_SECRET=replace_with_a_random_32_plus_character_secret
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

DB_HOST=localhost
DB_PORT=5432
DB_NAME=madsuite
DB_USER=postgres
DB_PASSWORD=change_me
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=15000
DB_STATEMENT_TIMEOUT_MS=15000
DB_MAX_POOL_SIZE=20

# EMAIL_HOST, EMAIL_PORT, EMAIL_USER et EMAIL_PASS doivent être configurés pour permettre l'envoi d'emails (ex: pour les notifications ou la réinitialisation de mot de passe)

REDIS_URL=redis://localhost:6379
FRONTEND_URL=https://app.madsuite.com
ELECTRON_URL=https://app.madsuite.com

ACTIVITY_LOG_RETENTION_DAYS=30
LONG_TIMER_THRESHOLD_HOURS=8
ENABLE_DB_BACKUP=0

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me

INVOICE_BRAND_NAME=MADSuite
INVOICE_BRAND_EMAIL=facturation@example.com
INVOICE_BRAND_PHONE=
INVOICE_BRAND_WEBSITE=https://example.com
INVOICE_BRAND_ADDRESS=
INVOICE_TAX_NUMBERS=
INVOICE_CURRENCY=CAD
INVOICE_PAYMENT_TERMS=Payable dans les 30 jours
INVOICE_BRAND_COLOR=#29529b
INVOICE_BRAND_FOOTER=Generated by MADSuite

# ----------------------------
# Frontend / Vite
# ----------------------------
VITE_API_URL=http://localhost:5000/api
GENERATE_SOURCEMAP=false

# ----------------------------
# Desktop agent
# ----------------------------
AGENT_API_URL=https://api.madsuite.com
AGENT_FRONTEND_URL=https://app.madsuite.com
AGENT_REFRESH_TIMEOUT_MS=15000
AGENT_BACKEND_DOWN_MAX_FAILURES=2
AGENT_BACKEND_DOWN_THROTTLE_MS=60000
AGENT_CAPTURE_QUEUE_MAX_ITEMS=200
AGENT_CAPTURE_QUEUE_MAX_BYTES=2000000
AGENT_CAPTURE_QUEUE_TTL_MS=604800000
AGENT_CAPTURE_QUEUE_FLUSH_DELAY_MS=30000
